---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>5280 Project LLC — Denver Construction & Renovation</title>
  <meta name="description" content="5280 Project LLC is Denver's trusted local construction company. General contracting, renovations, and site work done right. Get your free estimate today." />
</head>
<body class="bg-[#0d0d0d] text-white">
  <Nav />

  <!-- ─── HERO ─────────────────────────────────────────────────── -->
  <section class="relative min-h-screen flex flex-col justify-between overflow-hidden">

    <!-- Background layers -->
    <div class="absolute inset-0 bg-[#0d0d0d]">
      <!-- Subtle grid -->
      <div class="absolute inset-0 opacity-[0.025]"
           style="background-image: linear-gradient(#fff 1px, transparent 1px), linear-gradient(90deg, #fff 1px, transparent 1px); background-size: 64px 64px;"></div>
      <!-- Diagonal gold accent line -->
      <div class="absolute top-0 right-0 w-px h-full bg-gradient-to-b from-transparent via-[#f0a500]/20 to-transparent" style="right: 15%;"></div>
      <!-- Faint large 5280 watermark -->
      <div class="absolute inset-0 flex items-center justify-end pointer-events-none select-none overflow-hidden pr-8">
        <span class="font-display font-bold text-white leading-none tracking-tighter"
              style="font-size: clamp(8rem, 30vw, 30rem); opacity: 0.018;">5280</span>
      </div>
      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-[#0d0d0d] to-transparent"></div>
    </div>

    <!-- Hero content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 flex flex-col justify-center flex-1 pt-40 pb-16">
      <div class="max-w-3xl">

        <!-- Eyebrow -->
        <div class="flex items-center gap-3 mb-10">
          <div class="h-px w-10 bg-[#f0a500]"></div>
          <span class="text-[#f0a500] text-xs font-bold uppercase tracking-[0.35em]">Denver, Colorado</span>
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold leading-[0.92] tracking-tight mb-8"
            style="font-size: clamp(3.5rem, 10vw, 8rem);">
          BUILT TO<br>
          <span class="text-[#f0a500]">LAST.</span><br>
          BUILT FOR<br>
          DENVER.
        </h1>

        <!-- Sub -->
        <p class="text-white/50 text-lg leading-relaxed max-w-lg mb-12">
          5280 Project LLC delivers honest construction, renovation, and site work across the Denver metro. No shortcuts. No runaround. Just solid work done right the first time.
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#contact"
             class="inline-flex items-center justify-center gap-3 bg-[#f0a500] hover:bg-[#cc8c00] text-black font-bold text-xs uppercase tracking-[0.2em] px-8 py-4 transition-colors duration-200">
            Get Free Estimate
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="#services"
             class="inline-flex items-center justify-center border border-white/15 hover:border-white/40 text-white/70 hover:text-white font-semibold text-xs uppercase tracking-[0.2em] px-8 py-4 transition-colors duration-200">
            Our Services
          </a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative z-10 border-t border-white/8 bg-[#0a0a0a]/60">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          {[
            { value: '10+',   label: 'Years Experience' },
            { value: '200+',  label: 'Projects Completed' },
            { value: '100%',  label: 'Licensed & Insured' },
            { value: '5,280', label: 'Feet Above the Rest' },
          ].map(stat => (
            <div>
              <div class="font-display text-3xl md:text-4xl font-bold text-[#f0a500] leading-none">{stat.value}</div>
              <div class="text-white/35 text-xs uppercase tracking-widest mt-2">{stat.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ─── SERVICES ──────────────────────────────────────────────── -->
  <section id="services" class="bg-[#111111] py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <!-- Header -->
      <div class="mb-20">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-[#f0a500]"></div>
          <span class="text-[#f0a500] text-xs font-bold uppercase tracking-[0.35em]">What We Do</span>
        </div>
        <h2 class="font-display text-5xl md:text-6xl font-bold leading-none">OUR SERVICES</h2>
      </div>

      <!-- Cards -->
      <div class="grid md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/5 border border-white/5">

        <!-- General Contracting -->
        <div class="p-10 group hover:bg-[#161616] transition-colors duration-300">
          <div class="w-11 h-11 border border-[#f0a500]/25 group-hover:border-[#f0a500]/60 flex items-center justify-center mb-8 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#f0a500]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div class="font-display text-2xl font-bold mb-4 leading-snug">General<br>Contracting</div>
          <p class="text-white/40 text-sm leading-relaxed">Full-service project management from groundbreaking to final walkthrough. We coordinate every trade, keep your timeline on track, and deliver on budget.</p>
          <ul class="mt-8 pt-8 border-t border-white/5 space-y-2.5 text-xs text-white/35 uppercase tracking-wider">
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>New Construction</li>
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Commercial Build-Outs</li>
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Full Project Management</li>
          </ul>
        </div>

        <!-- Renovations -->
        <div class="p-10 group hover:bg-[#161616] transition-colors duration-300">
          <div class="w-11 h-11 border border-[#f0a500]/25 group-hover:border-[#f0a500]/60 flex items-center justify-center mb-8 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#f0a500]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
          </div>
          <div class="font-display text-2xl font-bold mb-4 leading-snug">Renovations &<br>Remodeling</div>
          <p class="text-white/40 text-sm leading-relaxed">Transform your space with expert craftsmanship. From kitchen and bath upgrades to whole-home transformations, we bring your vision to life.</p>
          <ul class="mt-8 pt-8 border-t border-white/5 space-y-2.5 text-xs text-white/35 uppercase tracking-wider">
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Kitchen & Bath</li>
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Whole-Home Remodels</li>
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Additions & ADUs</li>
          </ul>
        </div>

        <!-- Site Work -->
        <div class="p-10 group hover:bg-[#161616] transition-colors duration-300">
          <div class="w-11 h-11 border border-[#f0a500]/25 group-hover:border-[#f0a500]/60 flex items-center justify-center mb-8 transition-colors duration-300">
            <svg class="w-5 h-5 text-[#f0a500]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/>
            </svg>
          </div>
          <div class="font-display text-2xl font-bold mb-4 leading-snug">Site Work &<br>Excavation</div>
          <p class="text-white/40 text-sm leading-relaxed">Solid foundations start with expert site prep. We handle excavation, grading, drainage, and foundation work to set your project up for success.</p>
          <ul class="mt-8 pt-8 border-t border-white/5 space-y-2.5 text-xs text-white/35 uppercase tracking-wider">
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Excavation & Grading</li>
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Foundation Prep</li>
            <li class="flex items-center gap-2.5"><span class="w-1 h-1 rounded-full bg-[#f0a500] shrink-0"></span>Drainage Solutions</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── ABOUT ──────────────────────────────────────────────────── -->
  <section id="about" class="bg-[#0d0d0d] py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 lg:gap-28 items-center">

        <!-- Left: copy -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="h-px w-10 bg-[#f0a500]"></div>
            <span class="text-[#f0a500] text-xs font-bold uppercase tracking-[0.35em]">About Us</span>
          </div>
          <h2 class="font-display font-bold leading-none mb-8" style="font-size: clamp(2.8rem, 6vw, 5rem);">
            DENVER<br>BUILT.<br>
            <span class="text-[#f0a500]">DENVER<br>PROUD.</span>
          </h2>
          <p class="text-white/45 leading-relaxed mb-5">
            We're a local crew that knows Denver inside and out — the soil, the codes, the climate. When you hire 5280 Project LLC, you're not dealing with a franchise or a faceless corporation. You're working directly with the people doing the work.
          </p>
          <p class="text-white/45 leading-relaxed mb-12">
            We take pride in straight talk, fair pricing, and workmanship that holds up. Every project gets the same attention whether it's a basement finish or a ground-up build.
          </p>

          <!-- Trust badges -->
          <div class="grid grid-cols-3 gap-3">
            {[
              { label: 'Licensed' },
              { label: 'Insured'  },
              { label: 'Local'    },
            ].map(b => (
              <div class="border border-white/8 py-4 px-3 text-center">
                <div class="w-2 h-2 rounded-full bg-[#f0a500] mx-auto mb-3"></div>
                <div class="text-white/50 text-xs uppercase tracking-widest">{b.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: visual card -->
        <div class="relative">
          <div class="bg-[#141414] border border-white/5 aspect-[4/5] relative overflow-hidden flex flex-col justify-end">
            <!-- Big watermark -->
            <div class="absolute inset-0 flex items-center justify-center pointer-events-none select-none">
              <span class="font-display font-bold text-white leading-none"
                    style="font-size: clamp(5rem, 18vw, 14rem); opacity: 0.04;">5280</span>
            </div>
            <!-- Bottom info bar -->
            <div class="relative z-10 p-8 border-t border-white/5">
              <div class="text-white/25 text-xs uppercase tracking-widest mb-1">Denver, CO · Est. 2014</div>
              <div class="font-display text-xl font-bold">5280 Project LLC</div>
            </div>
          </div>
          <!-- Gold accent square -->
          <div class="absolute -bottom-5 -right-5 w-28 h-28 bg-[#f0a500] flex flex-col items-center justify-center">
            <div class="font-display text-3xl font-bold text-black leading-none">10+</div>
            <div class="text-black/70 text-xs font-bold uppercase tracking-wider mt-1">Years</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PROCESS ───────────────────────────────────────────────── -->
  <section id="process" class="bg-[#111111] py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">

      <div class="mb-20">
        <div class="flex items-center gap-3 mb-5">
          <div class="h-px w-10 bg-[#f0a500]"></div>
          <span class="text-[#f0a500] text-xs font-bold uppercase tracking-[0.35em]">How It Works</span>
        </div>
        <h2 class="font-display text-5xl md:text-6xl font-bold leading-none">OUR PROCESS</h2>
      </div>

      <div class="grid md:grid-cols-4 border border-white/5 divide-y md:divide-y-0 md:divide-x divide-white/5">
        {[
          { n: '01', title: 'Free Consult',    body: 'Tell us about your project. We visit the site, ask the right questions, and get a clear picture of what needs to happen.' },
          { n: '02', title: 'Detailed Plan',   body: 'You get a clear, itemized estimate with a realistic timeline. No vague quotes. No surprise change orders down the road.' },
          { n: '03', title: 'We Build',        body: 'Our crew gets to work. You get regular updates and direct communication from the people actually on the job.' },
          { n: '04', title: 'Delivered',       body: "Final walkthrough together. We don't call it done until you're satisfied — that's our word and our reputation.", gold: true },
        ].map(step => (
          <div class={`p-8 lg:p-10 ${step.gold ? 'bg-[#0f0f0f]' : ''}`}>
            <div class={`font-display text-7xl font-bold leading-none mb-5 ${step.gold ? 'text-[#f0a500]/15' : 'text-white/5'}`}>{step.n}</div>
            <div class={`font-display text-lg font-bold mb-3 uppercase tracking-wide ${step.gold ? 'text-[#f0a500]' : ''}`}>{step.title}</div>
            <p class="text-white/35 text-sm leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── WHY US STRIP ──────────────────────────────────────────── -->
  <section class="bg-[#f0a500] py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-12">
        {[
          { title: 'Straight Talk',    body: "We give you honest assessments and real numbers up front. If something will cost more or take longer, you hear it from us first." },
          { title: 'On-Time Delivery', body: "Schedules aren't suggestions. We plan the work, work the plan, and keep you in the loop every step of the way." },
          { title: 'Local Expertise',  body: "We know Denver's codes, climate, and soil. No learning curve on your dime — we've built here for over a decade." },
        ].map(item => (
          <div>
            <div class="w-8 h-0.5 bg-black/30 mb-5"></div>
            <div class="font-display text-xl font-bold text-black mb-3 uppercase tracking-wide">{item.title}</div>
            <p class="text-black/60 text-sm leading-relaxed">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CONTACT ───────────────────────────────────────────────── -->
  <section id="contact" class="bg-[#0d0d0d] py-32">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-16 lg:gap-28">

        <!-- Left: info -->
        <div>
          <div class="flex items-center gap-3 mb-5">
            <div class="h-px w-10 bg-[#f0a500]"></div>
            <span class="text-[#f0a500] text-xs font-bold uppercase tracking-[0.35em]">Get In Touch</span>
          </div>
          <h2 class="font-display font-bold leading-none mb-8" style="font-size: clamp(2.8rem, 6vw, 5rem);">
            START YOUR<br>
            <span class="text-[#f0a500]">PROJECT</span><br>
            TODAY.
          </h2>
          <p class="text-white/40 leading-relaxed mb-12 max-w-sm">
            Fill out the form and we'll get back to you within one business day with a free, no-obligation estimate.
          </p>

          <div class="space-y-7">
            <!-- Phone -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 border border-[#f0a500]/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#f0a500]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                </svg>
              </div>
              <div>
                <div class="text-white/25 text-xs uppercase tracking-widest mb-1">Phone</div>
                <a href="tel:5555555280" class="text-white hover:text-[#f0a500] font-medium transition-colors text-sm">(555) 555-5280</a>
              </div>
            </div>
            <!-- Email -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 border border-[#f0a500]/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#f0a500]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <div class="text-white/25 text-xs uppercase tracking-widest mb-1">Email</div>
                <a href="mailto:hello@5280construction.com" class="text-white hover:text-[#f0a500] font-medium transition-colors text-sm">hello@5280construction.com</a>
              </div>
            </div>
            <!-- Location -->
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 border border-[#f0a500]/20 flex items-center justify-center shrink-0 mt-0.5">
                <svg class="w-4 h-4 text-[#f0a500]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <div class="text-white/25 text-xs uppercase tracking-widest mb-1">Location</div>
                <div class="text-white font-medium text-sm">Denver Metro Area, CO</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: form -->
        <div>
          <form class="space-y-5">
            <div class="grid grid-cols-2 gap-5">
              <div>
                <label class="block text-white/30 text-xs uppercase tracking-widest mb-2">First Name</label>
                <input type="text" placeholder="John"
                       class="w-full bg-[#161616] border border-white/8 focus:border-[#f0a500] text-white placeholder-white/15 px-4 py-3 outline-none transition-colors text-sm" />
              </div>
              <div>
                <label class="block text-white/30 text-xs uppercase tracking-widest mb-2">Last Name</label>
                <input type="text" placeholder="Smith"
                       class="w-full bg-[#161616] border border-white/8 focus:border-[#f0a500] text-white placeholder-white/15 px-4 py-3 outline-none transition-colors text-sm" />
              </div>
            </div>
            <div>
              <label class="block text-white/30 text-xs uppercase tracking-widest mb-2">Email</label>
              <input type="email" placeholder="john@example.com"
                     class="w-full bg-[#161616] border border-white/8 focus:border-[#f0a500] text-white placeholder-white/15 px-4 py-3 outline-none transition-colors text-sm" />
            </div>
            <div>
              <label class="block text-white/30 text-xs uppercase tracking-widest mb-2">Phone</label>
              <input type="tel" placeholder="(720) 555-0000"
                     class="w-full bg-[#161616] border border-white/8 focus:border-[#f0a500] text-white placeholder-white/15 px-4 py-3 outline-none transition-colors text-sm" />
            </div>
            <div>
              <label class="block text-white/30 text-xs uppercase tracking-widest mb-2">Service Needed</label>
              <select class="w-full bg-[#161616] border border-white/8 focus:border-[#f0a500] text-white/60 px-4 py-3 outline-none transition-colors text-sm appearance-none cursor-pointer">
                <option value="">Select a service…</option>
                <option>General Contracting</option>
                <option>Renovation / Remodel</option>
                <option>Site Work & Excavation</option>
                <option>Other</option>
              </select>
            </div>
            <div>
              <label class="block text-white/30 text-xs uppercase tracking-widest mb-2">Project Details</label>
              <textarea rows="4" placeholder="Tell us about your project…"
                        class="w-full bg-[#161616] border border-white/8 focus:border-[#f0a500] text-white placeholder-white/15 px-4 py-3 outline-none transition-colors text-sm resize-none"></textarea>
            </div>
            <button type="submit"
                    class="w-full flex items-center justify-center gap-3 bg-[#f0a500] hover:bg-[#cc8c00] text-black font-bold text-xs uppercase tracking-[0.2em] py-4 transition-colors duration-200">
              Send My Request
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── FOOTER ────────────────────────────────────────────────── -->
  <footer class="bg-black border-t border-white/5 pt-20 pb-10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="grid md:grid-cols-4 gap-12 mb-16">

        <!-- Brand -->
        <div class="md:col-span-2">
          <div class="flex items-center gap-3 mb-5">
            <span class="font-display text-3xl font-bold text-white leading-none">5280</span>
            <div class="h-5 w-px bg-[#f0a500]/50"></div>
            <span class="text-xs font-bold text-white/35 uppercase tracking-[0.2em]">Project LLC</span>
          </div>
          <p class="text-white/30 text-sm leading-relaxed max-w-xs">
            Denver's local construction and renovation contractor. Built on quality, driven by reputation.
          </p>
          <div class="mt-6 text-xs text-white/15 uppercase tracking-widest">Denver, Colorado · Licensed & Insured</div>
        </div>

        <!-- Services links -->
        <div>
